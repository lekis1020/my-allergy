# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Sync auth
CRON_SECRET=your_random_secret
CRON_SYNC_DAYS=365
NOTIFICATION_LOOKBACK_HOURS=25

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_FEED=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX

# Inngest
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# External APIs
PUBMED_API_KEY=your_pubmed_api_key
CROSSREF_EMAIL=you@example.com

# Community (anonymous comments) — server-only salt used to derive anon_id
# per (pmid, user). Rotate with care: existing anon_ids will change.
COMMUNITY_SALT=change_me_to_a_long_random_string
